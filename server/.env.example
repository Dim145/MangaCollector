# Server
PORT=3000

# Auth — set AUTH_MODE to "google" or "openidconnect"
AUTH_MODE=google
AUTH_CLIENT_ID=your-client-id
AUTH_CLIENT_SECRET=your-client-secret

# Only required when AUTH_MODE=openidconnect
# AUTH_ISSUER=https://your-oidc-provider.example.com

# Display name and icon shown on the login page
AUTH_NAME=Google
AUTH_ICON=google

# Session
SESSION_SECRET=change-me-to-a-long-random-string

# URLs
FRONTEND_URL=http://localhost:12000

# Database
POSTGRES_URL=postgres://user:password@localhost:5432/manga_collector

# Storage — leave all S3_* unset to use local filesystem instead
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=manga-collector
S3_REGION=us-east-1
S3_USE_SSL=false
S3_USE_PATH_STYLE=true

# Local storage fallback (used when S3 vars are not set)
STORAGE_DIR=./storage

# Health check — set to "true" to allow health check from any IP
APP_UNSECURE_HEALTHCHECK=false

# ── Backend error tracking (Sentry / Bugsink) ───────────────────────
# Pick exactly ONE provider. Setting both DSNs aborts startup.
# Leaving both unset disables backend error tracking entirely.
#
# SENTRY_DSN works for the official Sentry cloud OR a self-hosted
# Sentry instance — both speak the same protocol.
# SENTRY_DSN=https://xxxxxxxx@o0.ingest.sentry.io/0000000
#
# BUGSINK_DSN points at a self-hosted Bugsink instance (wire-compatible
# with the Sentry SDK).
# BUGSINK_DSN=https://xxxxxxxx@bugsink.example.com/0
#
# Optional metadata applied to every event.
# SENTRY_ENVIRONMENT=production
#
# Performance traces — float in [0.0, 1.0]. 0.0 = errors only (default).
# 0.1 = sample 10% of requests as transactions.
# SENTRY_TRACES_SAMPLE_RATE=0.0

# ── Frontend integrations (served to the SPA at runtime) ────────────
# Two distinct injection paths, both env-driven (no rebuild on change):
#
# 1. Umami — read by the NGINX container's entrypoint, substituted via
#    envsubst into index.html and the CSP header at startup. Synchronous
#    availability means pageviews are tracked from the very first
#    navigation, no fetch round-trip.
#
# 2. Sentry / Bugsink — read by the BACKEND, served to the SPA via
#    GET /api/public-config (cached aggressively by the service worker
#    for offline boots). Init is non-blocking: React mounts immediately
#    and the SDK is wired when the response arrives. On any failure
#    (network, 5xx, no cache on first install) the SDK silently stays
#    off — the core app remains usable.

# Analytics — Umami. Both must be set for the script tag to inject.
# SPA route changes are auto-tracked (history.pushState hook).
# FRONTEND_UMAMI_SCRIPT_URL=https://umami.example.com/script.js
# FRONTEND_UMAMI_WEBSITE_ID=00000000-0000-0000-0000-000000000000
#
# Optional override — if your Umami origin differs from the script URL
# (rare; typical setups have script on the analytics origin). Defaults
# to the scheme+host of FRONTEND_UMAMI_SCRIPT_URL.
# FRONTEND_UMAMI_ORIGIN=https://umami.example.com

# Frontend error tracking — same mutex as the backend (validated at
# boot, server refuses to start if both are set). Independent from the
# backend DSN: typical setups use one Sentry/Bugsink project per
# service, but pointing both at the same project also works.
# FRONTEND_SENTRY_DSN=https://xxxxxxxx@o0.ingest.sentry.io/0000000
# FRONTEND_BUGSINK_DSN=https://xxxxxxxx@bugsink.example.com/0

# Optional metadata.
# FRONTEND_SENTRY_ENVIRONMENT=production
# FRONTEND_SENTRY_RELEASE=2.9.0
# FRONTEND_SENTRY_TRACES_SAMPLE_RATE=0.0
# FRONTEND_SENTRY_REPLAY=false
